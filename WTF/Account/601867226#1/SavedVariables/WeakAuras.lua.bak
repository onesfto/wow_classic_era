["hide_all_glows"] = true,
},
["init"] = {
["custom"] = "aura_env.icebolt = GetSpellInfo(28522)\naura_env.breath = GetSpellInfo(28524)\naura_env.counter = 0",
["do_custom"] = true,
},
},
["triggers"] = {
{
["trigger"] = {
["duration"] = "25",
["names"] = {
},
["debuffType"] = "HELPFUL",
["type"] = "custom",
["subeventSuffix"] = "_AURA_APPLIED",
["custom_hide"] = "custom",
["dynamicDuration"] = true,
["event"] = "Combat Log",
["unit"] = "player",
["spellIds"] = {
},
["customName"] = "function()\n    return aura_env.counter\nend\n\n\n",
["events"] = "CLEU:SPELL_AURA_APPLIED ENCOUNTER_START CLEU:SPELL_CAST_SUCCESS",
["subeventPrefix"] = "SPELL",
["custom"] = "function(e, ...)\n    if e == \"ENCOUNTER_START\" then\n        aura_env.counter = 0\n    elseif e == \"COMBAT_LOG_EVENT_UNFILTERED\" then\n        if (select(2,...)) == \"SPELL_AURA_APPLIED\" then            \n            local spellAura = (select(13,...))\n            if spellAura == aura_env.icebolt then\n                aura_env.counter = (aura_env.counter%3)+1\n                return true\n            end\n        end\n    end\nend\n\n\n\n\n",
["use_spellId"] = false,
["unevent"] = "timed",
["custom_type"] = "event",
},
["untrigger"] = {
["custom"] = "function(e,...)\n    if (select(2,...)) == \"SPELL_CAST_SUCCESS\" then\n        return (select(13,...)) == aura_env.breath\n    end\nend\n\n\n\n",
},
