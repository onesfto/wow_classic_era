},
["adjustedMax"] = "",
["customText"] = "function()\n    if WeakAuras.IsOptionsOpen() then\n        return \"冰霜攻击\\n123/200\"\n    end\nend\n\n\n",
["yOffset"] = 0,
["anchorPoint"] = "CENTER",
["cooldownSwipe"] = true,
["url"] = "https://afdian.com/a/Rurutia",
["icon"] = true,
["triggers"] = {
{
["trigger"] = {
["type"] = "custom",
["subeventSuffix"] = "_CAST_START",
["custom_type"] = "status",
["customStacks"] = "function()\n    return aura_env.count\nend",
["event"] = "Health",
["unit"] = "player",
["subeventPrefix"] = "SPELL",
["customName"] = "",
["spellIds"] = {
},
["names"] = {
},
["check"] = "event",
["events"] = "CLEU:SPELL_CAST_SUCCESS,CLEU:SPELL_DAMAGE,CLEU:RANGE_DAMAGE,CLEU:UNIT_DIED,PLAYER_REGEN_ENABLED ",
["custom"] = "function(event,...)\n    if event == \"COMBAT_LOG_EVENT_UNFILTERED\" and  ...  then\n        local subEvent,_ = select(2,...)\n        local destName,_ = select(9,...)\n        local spellName,_,_,_,school = select(13,...)\n        \n        if aura_env.active and subEvent and subEvent:find(\"DAMAGE\") then\n            if destName and school and destName == \"维希度斯\" and school == 16 then\n                aura_env.count = aura_env.count + 1\n                return true\n            end\n            \n            -- 小水滴死亡重置    \n        elseif subEvent and subEvent == \"UNIT_DIED\" and destName and destName == \"维希度斯水滴\" then\n            aura_env.count = 0\n            aura_env.active = true\n            return true\n            \n            -- 维希度斯重组重置  \n        elseif subEvent and subEvent == \"SPELL_CAST_SUCCESS\" and spellName and spellName == \"Rejoin Viscidus\" then\n            aura_env.count = 0\n            aura_env.active = true\n        end\n    end\nend",
["debuffType"] = "HELPFUL",
},
["untrigger"] = {
["custom"] = "function(event)\n    if aura_env.count >= 200 then\n        aura_env.count = 200\n        aura_env.active = false\n        return true\n    end\n    if event == \"PLAYER_REGEN_ENABLED\" then\n        aura_env.count = 0\n        aura_env.active = true\n        return true\n    end\nend",
},
},
