["actions"] = {
["start"] = {
},
["init"] = {
["do_custom"] = true,
["custom"] = "--Author: 露露緹婭@Bilibili\nlocal e = aura_env\nlocal region = WeakAuras.GetRegion(e.id) \n\nif not _G[e.id..\"Button\"] then \n    e.btn = CreateFrame(\"Button\", e.id..\"Button\", region) \n    e.btn:RegisterForClicks(\"AnyUp\")\n    e.btn:SetAllPoints(region)\nend\n\nlocal btn = _G[e.id..\"Button\"]\n\nbtn:SetScript(\"OnClick\", function(self, button)\n        local adName = {\"MeetingHorn\", \"MeetingStone\"}\n        for k, v in ipairs(adName) do \n            local isLoaded = false\n            if C_AddOns and C_AddOns.IsAddOnLoaded then\n                isLoaded = C_AddOns.IsAddOnLoaded(v)\n            elseif IsAddOnLoaded then\n                isLoaded = IsAddOnLoaded(v)\n            end\n            \n            if isLoaded then\n                local addon = LibStub('AceAddon-3.0'):GetAddon(v, true)\n                if addon then \n                    addon:Toggle()\n                end\n                break\n            end\n        end\nend)\n\nbtn:SetScript(\"OnMouseUp\", function(self)\n        region:SetAlpha(1)\nend)\n\nbtn:SetScript(\"OnMouseDown\", function(self)\n        region:SetAlpha(0.5)\nend)\n\nbtn:SetScript(\"OnEnter\",function(self)\n        region:SetScale(1)\nend)\n\nbtn:SetScript(\"OnLeave\",function(self)        \n        region:SetScale(1)\nend)",
},
