["init"] = {
["do_custom_load"] = false,
["custom"] = "local e = aura_env\nlocal leftID, rightID = 20749, 20749\n\nlocal btn = _G[e.id..\"Button\"] or CreateFrame(\n    \"Button\",\n    e.id..\"Button\",\n    WeakAuras.GetRegion(e.id),\n    \"SecureActionButtonTemplate\"\n)\n\nbtn:RegisterForClicks(\"LeftButtonUp\", \"RightButtonUp\")\nbtn:SetAllPoints(true)\n\n-- 左键使用 18262，并作用于主手 16\nbtn:SetAttribute(\"type1\", \"macro\")\nbtn:SetAttribute(\n    \"macrotext1\",\n    \"/use item:\"..leftID..\"\\n/use 16\\n/click StaticPopup1Button1\"\n)\n\n-- 右键使用 12404，并作用于主手 16\nbtn:SetAttribute(\"type2\", \"macro\")\nbtn:SetAttribute(\n    \"macrotext2\",\n    \"/use item:\"..rightID..\"\\n/use 16\\n/click StaticPopup1Button1\"\n)\n\nbtn:SetScript(\"OnEnter\", function(self)\n        GameTooltip:SetOwner(self, \"ANCHOR_RIGHT\")\n        GameTooltip:SetText(\n            \"左键主手: \"..(GetItemInfo(leftID) or (\"物品 ID: \"..leftID))..\"\\n\"..\n            \"右键主手: \"..(GetItemInfo(rightID) or (\"物品 ID: \"..rightID))\n        )\n        GameTooltip:Show()\nend)\n\nbtn:SetScript(\"OnLeave\", function()\n        GameTooltip:Hide()\nend)\n\ne.btn = btn\n\n",
["do_custom"] = true,
},
