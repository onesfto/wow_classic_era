["height"] = 30,
["textureSource"] = "LSM",
["glowLines"] = 8,
["sparkBlendMode"] = "ADD",
["useAdjustededMax"] = false,
["spark"] = false,
["source"] = "import",
["uid"] = "NdY1yhRdahS",
["useAdjustedMin"] = false,
["useAdjustedMax"] = false,
["cooldown"] = true,
["cooldownTextDisabled"] = false,
["width"] = 300,
["config"] = {
