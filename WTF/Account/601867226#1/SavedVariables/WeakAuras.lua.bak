["icon"] = true,
["triggers"] = {
{
["trigger"] = {
["type"] = "custom",
["subeventSuffix"] = "_CAST_START",
["custom_hide"] = "timed",
["customVariables"] = "{\n    completed = \"bool\"\n    \n}",
["event"] = "Health",
["subeventPrefix"] = "SPELL",
["unit"] = "player",
["custom"] = "function(allstates, event, ...)\n    for _, state in pairs(allstates) do\n        state.show = false\n        state.changed = true\n    end\n    for i, v in ipairs(aura_env.sodp4consumes) do\n        if v.itemEnabled == true then\n            local itemName = v.itemName\n            local itemID = v.itemID\n            local itemLink = v.itemString\n            allstates[itemID] = allstates[itemID] or {}\n            local state = allstates[itemID]\n            \n            local _, _, _, _, _, _, _, _,_, itemIcon = GetItemInfo(itemLink)\n            local itemCount = GetItemCount(itemLink)\n            \n            state.name = itemName\n            state.icon = itemIcon\n            state.progressType = 'static'\n            state.value = itemCount\n            state.autoHide = true\n            state.show = true\n            state.glow = true\n            state.completed = itemCount >= 1\n            state.index = itemName\n            state.changed = true\n        end\n    end\n    return true\nend",
