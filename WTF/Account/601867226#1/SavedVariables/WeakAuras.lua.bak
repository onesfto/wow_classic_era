["customText"] = "function(...)\n    local state = aura_env.states[2]\n\n    if not state or not state.expirationTime then\n        return\n    end\n\n    local remaining = state.expirationTime - GetTime()\n\n    if remaining >= 60 then\n        return math.ceil(remaining / 60) .. \" m\"\n    elseif remaining > 0 then\n        return math.floor(remaining) .. \" s\"\n    end\nend",
