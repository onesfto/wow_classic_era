["actions"] = {
["start"] = {
},
["init"] = {
["do_custom"] = true,
["custom"] = "local e = aura_env\nlocal leftID, rightID = 21151, 18269\n\nlocal btn = _G[e.id..\"Button\"] or CreateFrame(\"Button\", e.id..\"Button\", WeakAuras.GetRegion(e.id), \"SecureActionButtonTemplate\")\nbtn:RegisterForClicks(\"LeftButtonUp\", \"RightButtonUp\")\nbtn:SetAllPoints(true)\n\nbtn:SetAttribute(\"type1\", \"item\")\nbtn:SetAttribute(\"type2\", \"item\")\nbtn:SetAttribute(\"item1\", \"item:\"..leftID)\nbtn:SetAttribute(\"item2\", \"item:\"..rightID)\n\nbtn:SetScript(\"OnEnter\", function(self)\n        GameTooltip:SetOwner(self, \"ANCHOR_RIGHT\")\n        \n        if leftID == rightID then\n            GameTooltip:SetText(GetItemInfo(leftID) or (\"物品 ID: \"..leftID))\n        else\n            GameTooltip:SetText(\n                \"左键: \"..(GetItemInfo(leftID) or leftID)..\"\\n\"..\n                \"右键: \"..(GetItemInfo(rightID) or rightID)\n            )\n        end\n        \n        GameTooltip:Show()\nend)\n\nbtn:SetScript(\"OnLeave\", function()\n        GameTooltip:Hide()\nend)",
},
["finish"] = {
},
},
["conditions"] = {
{
["check"] = {
