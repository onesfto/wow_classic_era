["displayText_format_1.percenthealth_gcd_gcd"] = true,
["customText"] = "function()\n    if WeakAuras.IsOptionsOpen() then\n        return \"55%血量\"\n    end\n    local init = UnitHealth(\"targettarget\")\n    local Name = UnitName(\"targettarget\")\n    local max = UnitHealthMax(\"targettarget\")\n    local perc\n    \n    if aura_env.state and Name ==\"血肉触须\"  then\n        aura_env.init = init\n        aura_env.perc = init / max *100\n        return Round(aura_env.perc)..\"%血量\"\n    end\nend\n\n\n\n\n\n",
