["custom_type"] = "status",
["check"] = "event",
["unit"] = "player",
["custom"] = "function(...)\n    local Stoicism = {\n        [70845] = true, -- Stoicism\n    }\n    \n    local spellId = select(13, ...)\n    \n    if spellId and Stoicism[spellId] then\n        aura_env.spellId = spellId\n        aura_env.spellName = select(14, ...)\n        aura_env:log('Trigger2', aura_env.spellId, aura_env.spellName)\n    end\n    \n    return\nend\n\n\n\n",
