["useCooldownModRate"] = true,
["width"] = 48,
["customText"] = "function()\n    if WeakAuras.IsOptionsOpen() then\n        return \"|cffffffff技能名|r\"\n    end\n    \n    local spellName = aura_env.state.spellName \n    or aura_env.state.name\n    \n    if not spellName and aura_env.state.spellId then\n        spellName = C_Spell.GetSpellName(aura_env.state.spellId)\n    end\n    \n    if not spellName then\n        return nil\n    end\n    \n    local nameInBrackets = spellName:match(\"%((.+)%)\")\n    if nameInBrackets then\n        spellName = nameInBrackets\n    end\n    \n    local shortNames = {\n        [\"强效怒气\"] = \"强怒\",\n        [\"火焰之盾\"] = \"献祭\",\n        [\"龙息红椒\"] = \"红椒\",\n        [\"地精火箭靴\"] = \"火箭靴\",\n        [\"侏儒火箭靴\"] = \"火箭靴\",\n    }\n    \n    -- 只处理三字及以上\n    if #spellName >= 3 then\n        return shortNames[spellName] or spellName\n    else\n        return spellName\n    end\nend",
