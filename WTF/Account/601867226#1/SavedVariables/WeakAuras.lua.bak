["冲锋OR拦截"] = {
["iconSource"] = -1,
["xOffset"] = -125,
["adjustedMax"] = "",
["customText"] = "function()\n    return aura_env.text or \"\"\nend",
["yOffset"] = 46,
["anchorPoint"] = "CENTER",
["cooldownSwipe"] = true,
["cooldownEdge"] = false,
["icon"] = true,
["triggers"] = {
{
["trigger"] = {
["type"] = "custom",
["subeventSuffix"] = "_CAST_START",
["debuffType"] = "HELPFUL",
["event"] = "Health",
["subeventPrefix"] = "SPELL",
["unit"] = "player",
["names"] = {
},
["events"] = "UNIT_POWER_UPDATE UPDATE_SHAPESHIFT_FORM PLAYER_REGEN_DISABLED PLAYER_REGEN_ENABLED PLAYER_ENTERING_WORLD",
["customIcon"] = "function()\n    return aura_env.icon\nend",
["custom_type"] = "event",
["custom"] = "function(event, unit)\n    if event == \"UNIT_POWER_UPDATE\" and unit ~= \"player\" then\n        return false\n    end\n    \n    local rage = UnitPower(\"player\", 1) or 0\n    local stance = GetShapeshiftForm() or 0\n    local inCombat = UnitAffectingCombat(\"player\")\n    \n    -- 战斗中只能使用拦截\n    if inCombat then\n        aura_env.icon = GetSpellTexture(20252)\n        \n        if stance == 3 then\n            aura_env.text = \"拦截\"\n        else\n            aura_env.text = \"切狂暴 → 拦截\"\n        end\n        \n        -- 非战斗，狂暴姿态且怒气达到35，推荐拦截\n    elseif stance == 3 and rage >= 35 then\n        aura_env.icon = GetSpellTexture(20252)\n        aura_env.text = \"拦截\"\n        \n        -- 其他脱战情况推荐冲锋\n    else\n        aura_env.icon = GetSpellTexture(100)\n        \n        if stance == 1 then\n            aura_env.text = \"冲锋\"\n        else\n            aura_env.text = \"切战斗 → 冲锋\"\n        end\n    end\n    \n    return true\nend",
["spellIds"] = {
},
["custom_hide"] = "custom",
},
["untrigger"] = {
["custom"] = "function()\n    return false\nend",
},
},
["activeTriggerMode"] = -10,
