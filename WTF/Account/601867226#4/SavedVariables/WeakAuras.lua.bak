["type"] = "custom",
["subeventPrefix"] = "SPELL",
["unevent"] = "timed",
["custom_type"] = "stateupdate",
["custom"] = "function(allstates, event, ...)\n    if aura_env.config.noSpore == false then\n        if event == \"COMBAT_LOG_EVENT_UNFILTERED\" then       \n            local subEvent = (select(2,...))\n            if subEvent == \"SPELL_CAST_SUCCESS\" then\n                local spellName = (select(13,...))\n                if spellName == aura_env.spore then\n                    aura_env.counter = (aura_env.counter%aura_env.config.nGroups)+1\n                    if aura_env.config.group == aura_env.counter then\n                        allstates[\"\"] = {\n                            show = true,\n                            changed = true,\n                            autoHide = true,\n                            duration = 12,\n                            expirationTime = GetTime() + 12,\n                            progressType = \"timed\",\n                        }\n                    end\n                end        \n            elseif subEvent == \"SPELL_AURA_APPLIED\" or subEvent == \"SPELL_AURA_REFRESH\" then\n                local spellAura = (select(13,...))\n                if spellAura == aura_env.bloom then\n                    if allstates[\"\"] then             \n                        allstates[\"\"].show = false\n                        allstates[\"\"].changed = true\n                        return true\n                    end\n                end\n            end\n        elseif event == \"ENCOUNTER_START\" then aura_env.counter = 0 end\n    end\nend\n\n\n\n\n\n",
