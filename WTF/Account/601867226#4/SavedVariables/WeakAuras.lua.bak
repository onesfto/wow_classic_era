["00-语音合集（BWL）"] = {
["outline"] = "OUTLINE",
["wagoID"] = "BmGg6ad84",
["parent"] = "【露露】纯语音项目组（BWL）",
["displayText_format_p_time_dynamic_threshold"] = 60,
["shadowYOffset"] = -1,
["anchorPoint"] = "CENTER",
["displayText_format_p_time_format"] = 0,
["customTextUpdate"] = "event",
["url"] = "https://afdian.com/a/Rurutia",
["actions"] = {
["start"] = {
["sound"] = " custom",
["do_sound"] = false,
},
["init"] = {
["custom"] = "--Author: 露露緹婭@Bilibili\naura_env.RurutiaFileLocation = \"Interface\\\\AddOns\\\\Rurutia_Raids\"\n\n-- 施法开始的语音列表（敌对单位）\naura_env.SCSList = {\n    -- 07-克洛玛古斯\n    [23310] = '【露露】时光.ogg', -- 时间流逝\n    [23312] = '【露露】时光.ogg', -- 时间流逝\n    [23313] = '【露露】酸液.ogg', -- 腐蚀酸液\n    [23314] = '【露露】酸液.ogg', -- 腐蚀酸液\n    [23315] = '【露露】点燃.ogg', -- 点燃躯体\n    [23316] = '【露露】点燃.ogg', -- 点燃躯体\n    [23308] = '【露露】焚烧.ogg', -- 焚烧\n    [23309] = '【露露】焚烧.ogg', -- 焚烧\n    [23187] = '【露露】冰霜.ogg', -- 冰霜灼烧\n    [23189] = '【露露】冰霜.ogg', -- 冰霜灼烧\n    -- 08-奈法利安\n    [22686] = '【露露】准备恐惧.ogg', -- 低沉咆哮\n}\n\n-- 施法成功的语音列表（敌对单位）\naura_env.SCCList = {\n}\n\n-- 施法开始的语音列表（所有单位，无需敌对性检查）\naura_env.SCSAList = {\n}\n\n-- 施法成功的语音列表（所有单位，无需敌对性检查）\naura_env.SCCAList = {\n}\n\n-- 获得光环的语音列表（所有单位）\naura_env.SAAList = {\n    -- 03-勒什雷尔\n    [24573] = '【露露】注意刷坦.ogg', -- 致死打击\n    -- 05-埃博诺克\n    [23340] = '【露露】换坦嘲讽.ogg', -- 埃博诺克之影\n    -- 06-弗莱格尔\n    [23342] = '【露露】宁神.ogg', -- 疯狂\n    -- 07-克洛玛古斯\n    [23128] = '【露露】宁神.ogg', -- 疯狂\n}\n\n-- 玩家获得的减益语音列表（仅玩家）\naura_env.SAADBPList = {\n    -- 02-堕落的瓦拉斯塔茲\n    [18173] = '【露露】快跑哟，笨笨被点名啦！.ogg', -- 燃烧刺激\n}\n\n-- 敌对单位获得的增益语音列表（仅敌对单位）\naura_env.SAABFEList = {\n}\n\n-- 光环移除的语音列表（所有单位）\naura_env.SARList = {\n}\n\n-- 特定法术的冷却时间配置（4秒冷却）\naura_env.LCDSpells = {\n}",
["do_custom"] = true,
},
["finish"] = {
["hide_all_glows"] = true,
},
},
["triggers"] = {
{
["trigger"] = {
["type"] = "custom",
["custom_type"] = "stateupdate",
["custom_hide"] = "timed",
["event"] = "Health",
["unit"] = "player",
["subeventSuffix"] = "_CAST_START",
["subeventPrefix"] = "SPELL",
["custom"] = "function(_, event, _, subEvent, _, sourceGUID, _, sourceFlags, _, destGUID, _, _, _, spellID, _, _, auraType)\n    -- 检查子事件类型，仅处理施法开始、施法成功、获得光环和光环移除事件\n    if subEvent ~= \"SPELL_CAST_START\" and subEvent ~= \"SPELL_CAST_SUCCESS\" \n    and subEvent ~= \"SPELL_AURA_APPLIED\" and subEvent ~= \"SPELL_AURA_REMOVED\" then\n        return -- 如果不是指定的事件类型，直接退出\n    end\n    \n    -- 有效性检查：确保 spellID 存在\n    if not spellID then\n        return -- 如果没有 spellID，直接退出\n    end\n    \n    -- 初始化变量：sound 用于存储要播放的语音文件，needHostileCheck 用于标记是否需要敌对性检查\n    local sound\n    local needHostileCheck = false\n    \n    -- 根据不同事件类型选择对应的语音列表和检查条件\n    if subEvent == \"SPELL_CAST_START\" then\n        -- 处理施法开始事件（SPELL_CAST_START）\n        -- 优先检查 SCSAList（针对所有单位，无需敌对性检查）\n        sound = aura_env.SCSAList and aura_env.SCSAList[spellID]\n        if not sound then\n            -- 如果 SCSAList 中未找到对应音效，则检查 SCSList（针对敌对单位，需要敌对性检查）\n            needHostileCheck = true\n            sound = aura_env.SCSList and aura_env.SCSList[spellID]\n        end\n    elseif subEvent == \"SPELL_CAST_SUCCESS\" then\n        -- 处理施法成功事件（SPELL_CAST_SUCCESS）\n        -- 优先检查 SCCAList（针对所有单位，无需敌对性检查）\n        sound = aura_env.SCCAList and aura_env.SCCAList[spellID]\n        if not sound then\n            -- 如果 SCCAList 中未找到对应音效，则检查 SCCList（针对敌对单位，需要敌对性检查）\n            needHostileCheck = true\n            sound = aura_env.SCCList and aura_env.SCCList[spellID]\n        end\n    elseif subEvent == \"SPELL_AURA_APPLIED\" then\n        -- 处理获得光环事件（SPELL_AURA_APPLIED）\n        -- 优先检查 SAAList（针对所有单位，无需单位过滤）\n        sound = aura_env.SAAList and aura_env.SAAList[spellID]\n        if not sound then\n            if destGUID == UnitGUID(\"player\") then\n                -- 如果光环目标是玩家，检查是否为减益（DEBUFF）\n                if auraType ~= \"DEBUFF\" then\n                    return -- 如果不是减益，直接退出\n                end\n                -- 检查 SAADBPList（仅针对玩家的减益）\n                sound = aura_env.SAADBPList and aura_env.SAADBPList[spellID]\n            else\n                -- 如果光环目标不是玩家，检查是否为敌对单位的增益（BUFF）\n                needHostileCheck = true\n                if auraType ~= \"BUFF\" then\n                    return -- 如果不是增益，直接退出\n                end\n                -- 检查 SAABFEList（仅针对敌对单位的增益）\n                sound = aura_env.SAABFEList and aura_env.SAABFEList[spellID]\n            end\n        end\n    elseif subEvent == \"SPELL_AURA_REMOVED\" then\n        -- 处理光环移除事件（SPELL_AURA_REMOVED）\n        -- 检查 SARList（针对所有单位的光环移除）\n        sound = aura_env.SARList and aura_env.SARList[spellID]\n    end\n    \n    -- 如果需要敌对性检查，验证施法者是否为敌对单位\n    if needHostileCheck and (not sourceGUID or not sourceFlags \n        or bit.band(sourceFlags, 0x40) == 0) then\n        return -- 如果施法者不是敌对单位，直接退出\n    end\n    \n    -- 检查是否找到对应音效\n    if not sound then\n        return -- 如果没有找到音效，直接退出\n    end\n    \n    -- 初始化播放时间记录表，用于防止短时间内重复播放\n    aura_env.lastPlayed = aura_env.lastPlayed or {}\n    local currentTime = GetTime() -- 获取当前时间\n    \n    -- 设置冷却时间：特定法术（在 LCDSpells 中定义）为 4 秒，其他为 2 秒\n    local cooldown = (aura_env.LCDSpells and aura_env.LCDSpells[spellID]) and 4 or 2\n    \n    -- 检查冷却时间，防止短时间内重复播放同一音效\n    if aura_env.lastPlayed[spellID] and (currentTime - aura_env.lastPlayed[spellID] < cooldown) then\n        return -- 如果未超过冷却时间，直接退出\n    end\n    \n    -- 播放声音文件并记录播放时间\n    PlaySoundFile(aura_env.RurutiaFileLocation .. \"\\\\\" .. sound, \"Master\")\n    aura_env.lastPlayed[spellID] = currentTime\nend",
["names"] = {
},
["check"] = "event",
["spellIds"] = {
},
["events"] = "CLEU:SPELL_CAST_START,CLEU:SPELL_CAST_SUCCESS,CLEU:SPELL_AURA_APPLIED,CLEU:SPELL_AURA_REMOVED",
["debuffType"] = "HELPFUL",
