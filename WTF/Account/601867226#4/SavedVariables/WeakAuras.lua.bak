},
["custom"] = "function(_,_,arg3,_,_,arg6,_,_,_,_,_,_,_,arg14,_,arg16, ...)\n    if arg3 == \"SPELL_MISSED\" and arg6 == GetUnitName(\"player\") and aura_env.config[\"reg\"][arg14] then\n        aura_env.name = arg6\n        aura_env.spell = arg14\n        aura_env.type = arg16\n        return true\n    end\nend",
