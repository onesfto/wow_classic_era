},
},
["hideReorder"] = true,
["useDesc"] = false,
["nameSource"] = 0,
["width"] = 1,
["useCollapse"] = true,
["collapse"] = false,
["name"] = "Spells",
["key"] = "reg",
["limitType"] = "none",
["groupType"] = "simple",
["type"] = "group",
["size"] = 10,
},
},
["preferToUpdate"] = false,
["customText"] = "function(n,s,t)\n    local type_ = \"\"\n    if aura_env.type == \"MISS\" then type_ = \"未命中\"\n    elseif aura_env.type == \"PARRY\" then type_ = \"招架\"\n    elseif aura_env.type == \"DODGE\" then type_ = \"躲闪\"\n    elseif aura_env.type ==\"IMMUNE\" then type_ = \"免疫\"\n    elseif aura_env.type == \"RESIST\"  then type_ = \"抵抗\"\n    elseif aura_env.type == \"BLOCK\" then type_ = \"格挡\"\n    end\n    local spell_ = \"\"\n    if aura_env.spell == \"厄运诅咒\" then spell_ = \"|T136122:0|t厄运\"\n        --    elseif aura_env.spell  == \"挑战怒吼\" then spell_ = \"|T132091:0|t挑战怒吼\"\n        --    elseif aura_env.spell  ==\"惩戒痛击\"  then spell_ = \"|T132350:0|t惩戒痛击\"\n        --    elseif aura_env.spell  == \"低吼\" then spell_ = \"|T132270:0|t低吼\"\n    end\n    if WeakAuras.IsOptionsOpen()  then\n        return \"|cff8787ed\"..UnitName(\"player\")..\"|r\",\"|T136122:0|t厄运\",\"|cffc41e3a\"..\"抵抗\"..\"|r\"\n    else\n        return  \"|cff8787ed\"..aura_env.name..\"|r\",spell_ ,\"|cffc41e3a\"..type_..\"|r\"\n    end\nend\n\n\n",
["yOffset"] = 150,
["anchorPoint"] = "CENTER",
["cooldownSwipe"] = true,
["cooldownTextDisabled"] = false,
["customTextUpdate"] = "event",
["url"] = "",
["icon"] = true,
["triggers"] = {
{
["trigger"] = {
["duration"] = "3",
