},
["cooldown"] = false,
["customText"] = "function(...)\n    \n    local str,sid,t\n    sid=11405\n    for i=1,40 do \n        local buffName, icon, count, debuffType, duration, expirationTime, caster, canStealOrPurge, _ , spellId, _, _, casterIsPlayer, nameplateShowAll =UnitBuff(\"player\",i) \n        if buffName and spellId == sid then \n            \n            t = -1*(GetTime()-expirationTime)\n            if t>=60 then\n                return math.ceil(t/60) ..\" m\"\n            elseif t >0 and  t <60 then \n                return math.floor(t) ..\" s\"\n            else\n                return\n            end      \n        end \n    end\n    \n    \nend",
},
