},
["init"] = {
["do_custom"] = true,
["custom"] = "local e = aura_env\nlocal leftID, rightID = 12451, 9206\n\nlocal btn = _G[e.id..\"Button\"] or CreateFrame(\n    \"Button\",\n    e.id..\"Button\",\n    WeakAuras.GetRegion(e.id),\n    \"SecureActionButtonTemplate\"\n)\n\nbtn:RegisterForClicks(\"LeftButtonUp\", \"RightButtonUp\")\nbtn:SetAllPoints(true)\n\n-- 左键：对自己使用 12451\nbtn:SetAttribute(\"type1\", \"macro\")\nbtn:SetAttribute(\"macrotext1\", \"/use [@player] item:\"..leftID)\n\n-- 右键：直接使用 9206\nbtn:SetAttribute(\"type2\", \"item\")\nbtn:SetAttribute(\"item2\", \"item:\"..rightID)\n\nbtn:SetScript(\"OnEnter\", function(self)\n        GameTooltip:SetOwner(self, \"ANCHOR_RIGHT\")\n        \n        GameTooltip:SetText(\n            \"左键: \"..(GetItemInfo(leftID) or (\"物品 ID: \"..leftID))..\"\\n\"..\n            \"右键: \"..(GetItemInfo(rightID) or (\"物品 ID: \"..rightID))\n        )\n        \n        GameTooltip:Show()\nend)\n\nbtn:SetScript(\"OnLeave\", function()\n        GameTooltip:Hide()\nend)\n\ne.btn = btn\n\n",
},
},
