["安其拉-预言者斯克拉姆-标记助手"] = {
["outline"] = "OUTLINE",
["wagoID"] = "zK_tu51Mg",
["xOffset"] = 0,
["displayText"] = "",
["customText"] = "",
["yOffset"] = 0,
["anchorPoint"] = "CENTER",
["displayText_format_p_time_format"] = 0,
["customTextUpdate"] = "event",
["url"] = "https://afdian.com/a/Rurutia",
["actions"] = {
["start"] = {
},
["init"] = {
},
