},
["columnSpace"] = 1,
["internalVersion"] = 90,
["rotation"] = 0,
["useLimit"] = false,
["align"] = "CENTER",
["yOffset"] = -10,
["anchorPoint"] = "CENTER",
["desc"] = "by Buds，https://wago.io/ClassicBuffMissing/\n露露备注：更新60可用&汉化，改为队伍/团队中并且脱战提示。\n修改：露露緹婭@Bilibili，抖音：露露缇娅。\n\n转载请保留出处，商用禁止。",
["stagger"] = 0,
["fullCircle"] = true,
["version"] = 10,
["subRegions"] = {
},
["rowSpace"] = 1,
["customAnchorPerUnit"] = "function(frames, activeRegions)\n    local function shouldIShow(unit, id)\n        if id:match(\"battle shout\") then\n            -- show only for party\n            if not UnitInParty(unit) then\n                return false\n            end\n            -- show only on warriors & rogues\n            local _, class = UnitClass(unit)\n            if class ~= \"WARRIOR\" and class ~= \"ROGUE\" then\n                return false\n            end\n        end\n        -- show intel & spirit only for mana classes\n        if (id:match(\"intellect\") or id:match(\"divine spirit\"))\n        and UnitPowerType(unit) ~= 0\n        then\n            return false\n        end\n        return true\n    end\n    \n    local function UnitGroup(unit)\n        local unitName = UnitName(unit)\n        if unitName then\n            for i = 1, 40 do\n                local name, _, subgroup = GetRaidRosterInfo(i)\n                if name == unitName then\n                    return subgroup\n                end\n            end\n        end\n    end\n    \n    for _, regionData in ipairs(activeRegions) do\n        local unit = regionData.region.state and regionData.region.state.unit\n        if unit and shouldIShow(unit, regionData.id) then\n            local skip = false\n            if regionData.data.config.filtergroups then\n                local unitSubgroup = UnitGroup(unit)\n                if type(unitSubgroup) == \"number\"\n                and not regionData.data.config.groups[unitSubgroup]\n                then\n                    skip = true\n                end\n            end\n            if not skip then\n                local frame = WeakAuras.GetUnitFrame(unit)\n                if frame then\n                    frames[frame] = frames[frame] or {}\n                    tinsert(frames[frame], regionData)\n                end\n            end\n        end\n    end\nend",
["load"] = {
["use_class"] = "true",
["talent"] = {
["multi"] = {
