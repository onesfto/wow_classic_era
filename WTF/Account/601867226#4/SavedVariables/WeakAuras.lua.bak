["borderBackdrop"] = "Blizzard Tooltip",
["parent"] = "红绿灯",
["desaturateBackground"] = false,
["crop_x"] = 0.41,
["displayText_format_p_format"] = "timed",
["cooldownEdge"] = false,
["model_x"] = 0,
["cooldownSwipe"] = true,
["startPercent"] = 0,
["customTextUpdate"] = "event",
["borderInset"] = 11,
["desaturateForeground"] = false,
["triggers"] = {
{
["trigger"] = {
["type"] = "custom",
["subeventSuffix"] = "_CAST_START",
["debuffType"] = "HELPFUL",
["event"] = "Health",
["unit"] = "player",
["events"] = "UNIT_HEAL_PREDICTION,UNIT_HEALTH",
["spellIds"] = {
},
["custom"] = "function(states, _, unit)\n    if unit then\n        local heal = 0\n        local source \n        local flag = 0\n        local index = 1\n        local count = 0\n        local threshold = aura_env.config.threshold or 0\n        local overPercent = aura_env.config.overPercent / 100 or 0\n        local timeNow = GetTime()*1000\n        -- initial\n        if not aura_env.healInfo[unit] then\n            aura_env.healInfo[unit] = {}\n        end\n        if not aura_env.healInfo[unit][\"index\"] then\n            aura_env.healInfo[unit][\"index\"] = index\n            aura_env.healInfo[unit][\"count\"] = index\n            for index = 1,2 do\n                aura_env.healInfo[unit][index] = {\n                    sourceUnit = \"player\",\n                    endTime = timeNow,\n                    healAmount = heal\n                }\n            end\n        end\n        \n        -- push heal inc into heal queue\n        for k,source in pairs(aura_env.healer) do\n            heal = UnitGetIncomingHeals(unit,source) or 0\n            index = aura_env.healInfo[unit][\"index\"]\n            \n            if  heal > threshold then\n                local spell, _, _, startTime, endTime = UnitCastingInfo(source)\n                if spell and endTime then\n                    if aura_env.healInfo[unit][index].endTime <= timeNow or aura_env.healInfo[unit][index].endTime >= endTime then \n                        --1st timeout or fastest\n                        if not UnitIsUnit(aura_env.healInfo[unit][index].sourceUnit, source) then\n                            --swap 1st and 2nd\n                            aura_env.healInfo[unit][\"index\"] = 2/index\n                            index = 2/index\n                        end\n                        aura_env.healInfo[unit][index].sourceUnit = source\n                        aura_env.healInfo[unit][index].endTime = endTime\n                        aura_env.healInfo[unit][index].healAmount = heal\n                    elseif aura_env.healInfo[unit][2/index].endTime <= timeNow and aura_env.healInfo[unit][2/index].endTime >= endTime then \n                        --2nd timeout or faster than 2nd\n                        aura_env.healInfo[unit][2/index].sourceUnit = source\n                        aura_env.healInfo[unit][2/index].endTime =  endTime\n                        aura_env.healInfo[unit][2/index].healAmount = heal\n                    end\n                end\n                count = count + 1\n            elseif UnitIsUnit(aura_env.healInfo[unit][index].sourceUnit, source) then \n                -- 1st inc heal canceled or completed ,swap 1st and 2nd\n                aura_env.healInfo[unit][index].endTime = timeNow\n                aura_env.healInfo[unit][index].healAmount = 0\n                aura_env.healInfo[unit][\"index\"] = 2/index\n            elseif UnitIsUnit(aura_env.healInfo[unit][2/index].sourceUnit, source) then\n                -- 2nd inc heal canceled or completed\n                aura_env.healInfo[unit][2/index].endTime = timeNow\n                aura_env.healInfo[unit][2/index].healAmount = 0\n            end\n        end\n        \n        -- query player heal inc\n        index = aura_env.healInfo[unit][\"index\"]\n        if UnitIsUnit(aura_env.healInfo[unit][index].sourceUnit,\"player\") then\n            flag = 0 -- player is first\n        elseif UnitIsUnit(aura_env.healInfo[unit][2/index].sourceUnit,\"player\")\n        and aura_env.healInfo[unit][2/index].healAmount > 0\n        and aura_env.healInfo[unit][2/index].endTime > timeNow\n        and (aura_env.healInfo[unit][index].healAmount + aura_env.healInfo[unit][2/index].healAmount + UnitHealth(unit)) <= (UnitHealthMax(unit) * (1 + overPercent))\n        then\n            flag = 0 -- player is not the first one but over heal is lower than threshold\n        else\n            flag = 1 -- other is first\n        end\n        \n        --[[\n        print(\"inc \"..tostring(aura_env.healInfo[unit][index].healAmount)..\" \"..tostring( aura_env.healInfo[unit][2/index].healAmount) ..\n            \" total \"..tostring(UnitHealthMax(unit) * (1 + overPercent))..\n            \" check \"..tostring((aura_env.healInfo[unit][index].healAmount + aura_env.healInfo[unit][2/index].healAmount + UnitHealth(unit)) <= (UnitHealthMax(unit) * (1 + overPercent)))..\n            \" flag \"..tostring(flag))\n        --]]\n        \n        -- make states\n        states[unit] = \n        {\n            changed = true,\n            show = count > 0,\n            unit = unit,\n            stacks = count,\n            progressType = \"static\",\n            value = flag,\n        }\n        \n    end\n    \n    return true\nend\n\n\n\n",
["names"] = {
},
["check"] = "event",
["subeventPrefix"] = "SPELL",
["custom_type"] = "stateupdate",
["customVariables"] = "\n\n",
},
["untrigger"] = {
},
},
{
["trigger"] = {
["type"] = "custom",
["custom"] = "function()\n    --reset\n    aura_env.healInfo = {}\n    aura_env.healer = {\"player\"}\n    aura_env.healerFlag = {}\n    aura_env.healerFlag[\"player\"] = true\n    \n    local unit \n    local unitClass\n    for unit in WA_IterateGroupMembers() do\n        local _,unitClass = UnitClass(unit);\n        if  (unitClass == \"PALADIN\" or unitClass == \"DRUID\" or unitClass == \"PRIEST\"  or unitClass == \"SHAMAN\")  and not UnitIsUnit(unit,\"player\") and not aura_env.healerFlag[unit] then\n            -- healer\n            tinsert(aura_env.healer,unit)\n            aura_env.healerFlag[unit] = true\n        end\n    end\n    --table.foreach(aura_env.healer, print) \n    \n    return false\nend",
