["hide_all_glows"] = true,
},
},
["triggers"] = {
{
["trigger"] = {
["type"] = "custom",
["subeventSuffix"] = "_CAST_START",
["event"] = "Health",
["unit"] = "player",
["custom_hide"] = "custom",
["custom"] = "function(event)\n    local opt\n    if aura_env.config.type == 2 then\n        opt = 3  -- 菱形标记\n    else\n        opt = 8  -- 骷髅标记\n    end\n    \n    -- 目标检测和GUID记录\n    if UnitName(\"target\") == \"预言者斯克拉姆\" then\n        if UnitHealth(\"target\")/UnitHealthMax(\"target\")  > 0.8 and aura_env.RealGUID ~= UnitGUID(\"target\") then\n            aura_env.RealGUID = UnitGUID(\"target\")\n        end\n    end\n    \n    -- 鼠标悬停自动标记\n    if event == \"UPDATE_MOUSEOVER_UNIT\" then\n        if UnitGUID(\"mouseover\") == aura_env.RealGUID then\n            if GetRaidTargetIndex(\"mouseover\") ~= opt then\n                SetRaidTarget(\"mouseover\",opt)\n            end\n        end\n    end\n    return true\nend",
["spellIds"] = {
},
["subeventPrefix"] = "SPELL",
["names"] = {
},
["custom_type"] = "event",
["events"] = "PLAYER_TARGET_CHANGED UPDATE_MOUSEOVER_UNIT",
["debuffType"] = "HELPFUL",
},
["untrigger"] = {
},
},
{
["trigger"] = {
["type"] = "custom",
["subeventSuffix"] = "_CAST_START",
["duration"] = "1",
["event"] = "Chat Message",
["subeventPrefix"] = "SPELL",
["events"] = "NAME_PLATE_UNIT_ADDED NAME_PLATE_UNIT_REMOVED",
["custom_type"] = "status",
["check"] = "event",
["unevent"] = "timed",
["custom"] = "function()\n    local opt\n    if aura_env.config.type == 2 then\n        opt = 3  -- 菱形标记\n    else\n        opt = 8  -- 骷髅标记\n    end\n    \n    -- 遍历所有姓名板\n    for i = 1,40 do\n        local unit = \"nameplate\"..i\n        if UnitExists(unit) and UnitGUID(unit) == aura_env.RealGUID then\n            if GetRaidTargetIndex(unit) ~= opt then\n                SetRaidTarget(unit,opt)\n            end\n        end\n    end\n    return true\nend\n\n\n",
["custom_hide"] = "custom",
},
