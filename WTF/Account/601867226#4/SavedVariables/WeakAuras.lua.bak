["tocversion"] = 11508,
["id"] = "战士斩杀",
["customText"] = "function()\n    local base, positive, negative = UnitAttackPower(\"player\")\n    local attackPower = (base or 0) + (positive or 0) + (negative or 0)\n    \n    local bloodthirstName = GetSpellInfo(23881) or \"嗜血\"\n    local usable, noRage = IsUsableSpell(bloodthirstName)\n    local start, duration, enabled = GetSpellCooldown(bloodthirstName)\n    \n    local bloodthirstReady =\n    attackPower >= 1000\n    and usable\n    and not noRage\n    and enabled == 1\n    and (duration == 0 or duration <= 1.6)\n    \n    if bloodthirstReady then\n        return \"嗜血\"\n    else\n        return \"斩杀\"\n    end\nend",
