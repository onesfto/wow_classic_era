["cooldown"] = false,
["customText"] = "function(...)\n    \n    local str,sid,t\n    local hasMainHandEnchant, mainHandExpiration, mainHandCharges,mainHandEnchantId = GetWeaponEnchantInfo()\n    if hasMainHandEnchant then\n        t = mainHandExpiration/1000\n        if t>=60 then\n            return math.ceil(t/60) ..\" m\"\n        elseif t >0 and  t <60 then \n            return math.floor(t) ..\" s\"\n        else\n            return\n        end      \n    end\n    return\n    \nend",
},
