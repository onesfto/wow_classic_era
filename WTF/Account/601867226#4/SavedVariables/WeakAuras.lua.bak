["init"] = {
["do_custom_load"] = false,
["custom"] = "local e = aura_env\n\nlocal function CreateMacroButton(itemID, macroText)\n    if _G[e.id..\"Button\"] then return _G[e.id..\"Button\"] end\n    \n    local btn = CreateFrame(\"Button\", e.id..\"Button\", WeakAuras.GetRegion(e.id), \"SecureActionButtonTemplate\")\n    btn:RegisterForClicks(\"LeftButtonUp\", \"RightButtonUp\")\n    btn:SetAllPoints(true)\n    e.btn = btn\n    \n    -- 左右键宏一致\n    btn:SetAttribute(\"type1\", \"macro\")\n    btn:SetAttribute(\"macrotext1\", macroText)\n    btn:SetAttribute(\"type2\", \"macro\")\n    btn:SetAttribute(\"macrotext2\", macroText)\n    \n    -- 鼠标悬停显示物品名字\n    btn:SetScript(\"OnEnter\", function(self)\n            GameTooltip:SetOwner(self, \"ANCHOR_RIGHT\")\n            if IsShiftKeyDown() then\n                GameTooltip:SetHyperlink(\"item:\"..itemID)\n            else\n                GameTooltip:SetText(GetItemInfo(itemID) or \"物品\")\n            end\n            GameTooltip:Show()\n    end)\n    \n    btn:SetScript(\"OnLeave\", GameTooltip_Hide)\n    \n    return btn\nend\n\nCreateMacroButton(\n    12404,\n    \"/use item:12404\\n/use 17\\n/click StaticPopup1Button1\"\n)",
["do_custom"] = true,
},
},
