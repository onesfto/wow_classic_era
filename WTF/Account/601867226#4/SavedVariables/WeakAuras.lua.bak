{
["trigger"] = {
["type"] = "custom",
["custom_type"] = "status",
["unit"] = "player",
["customName"] = "function()\n    return aura_env.skillName or \"斩杀\"\nend",
["custom"] = "function()\n    local base, positive, negative = UnitAttackPower(\"player\")\n    local attackPower = (base or 0) + (positive or 0) + (negative or 0)\n    \n    local rage = UnitPower(\"player\", 1) or 0\n    \n    local bloodthirstID = 23881\n    local executeID = 20662\n    \n    local start, duration, enabled = GetSpellCooldown(bloodthirstID)\n    \n    start = start or 0\n    duration = duration or 0\n    \n    local remaining = 0\n    \n    if start > 0 and duration > 0 then\n        remaining = math.max(0, start + duration - GetTime())\n    end\n    \n    local bloodthirstReady =\n    attackPower >= 2000\n    and rage >= 30\n    and enabled ~= 0\n    and remaining <= 1.6\n    \n    if bloodthirstReady then\n        aura_env.skillName = \"嗜血\"\n        aura_env.skillIcon = GetSpellTexture(bloodthirstID)\n    else\n        aura_env.skillName = \"斩杀\"\n        aura_env.skillIcon = GetSpellTexture(executeID)\n    end\n    \n    return true\nend",
["customIcon"] = "function()\n    return aura_env.skillIcon or GetSpellTexture(20662)\nend",
["check"] = "event",
["events"] = "UNIT_ATTACK_POWER:player UNIT_POWER_FREQUENT:player SPELL_UPDATE_COOLDOWN ACTIONBAR_UPDATE_COOLDOWN UPDATE_SHAPESHIFT_FORM PLAYER_ENTERING_WORLD",
