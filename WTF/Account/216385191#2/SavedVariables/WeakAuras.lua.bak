["finish"] = {
["custom"] = "",
["do_custom"] = false,
},
["init"] = {
["custom"] = "local _, myClass = UnitClass(\"player\")\n\nlocal allBuffs = {\n    PRIEST = {\n        [1245] = true,\n        [14818] = true,\n    },\n    MAGE = {\n        [1460] = true,\n    },\n    DRUID = {\n        [9885] = true,\n    },\n    WARRIOR = {\n        [11551] = true,\n    }\n}\n\nlocal myBuffs = allBuffs[myClass]\n\nfunction aura_env.shouldIShow(unit, spellId)\n    if aura_env.config.showAll then\n        return true\n    end\n    \n    if myClass == \"WARRIOR\" and not UnitInParty(unit) then\n        return false\n    end\n    if myClass == \"MAGE\" and UnitPowerType(unit) ~= 0 then\n        return false\n    end\n    if myClass == \"PRIEST\" and spellId == \"14818\" and UnitPowerType(unit) ~= 0 then\n        return false\n    end\n    \n    return myBuffs and myBuffs[tonumber(spellId)]\nend\n\n\n",
["do_custom"] = false,
},
},
