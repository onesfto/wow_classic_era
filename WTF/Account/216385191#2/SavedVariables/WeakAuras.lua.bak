["法力红宝石"] = {
["iconSource"] = 1,
["xOffset"] = 0,
["adjustedMax"] = "",
["adjustedMin"] = "",
["yOffset"] = 0,
["anchorPoint"] = "CENTER",
["cooldownSwipe"] = true,
["cooldownEdge"] = false,
["actions"] = {
["start"] = {
["custom"] = "local btn = aura_env.button or _G[aura_env.id .. \"Button\"]\n\nif btn then\n    btn:Show()\nend",
["do_custom"] = true,
},
["finish"] = {
["custom"] = "local btn = aura_env.button or _G[aura_env.id .. \"Button\"]\n\nif btn then\n    btn:Hide()\nend",
["do_custom"] = true,
},
["init"] = {
["custom"] = "local e = aura_env\nlocal region = WeakAuras.GetRegion(e.id)\nif not region then return end\n\n-- 将主要物品ID改为 8008，用于鼠标悬停提示和左键点击\naura_env.itemid = 8008\n\nlocal btnName = e.id .. \"Button\"\nlocal btn = _G[btnName]\n\nif not btn then\n    btn = CreateFrame(\"Button\", btnName, region, \"SecureActionButtonTemplate\")\n    btn:SetAllPoints(region)\n    btn:RegisterForClicks(\"LeftButtonUp\", \"RightButtonUp\")\n    btn:EnableMouse(true)\n    btn:SetFrameLevel(region:GetFrameLevel() + 20)\n    \n    btn:SetScript(\"OnEnter\", function(self)\n            GameTooltip:SetOwner(self, \"ANCHOR_RIGHT\")\n            \n            if aura_env.itemid then\n                GameTooltip:SetItemByID(aura_env.itemid)\n            else\n                GameTooltip:SetText(\"未绑定物品\")\n            end\n            \n            GameTooltip:Show()\n    end)\n    \n    btn:SetScript(\"OnLeave\", function()\n            GameTooltip:Hide()\n    end)\nend\n\n-- 安全按钮属性：必须尽量在非战斗状态设置\nif not InCombatLockdown() then\n    -- 左键：使用物品 8008\n    btn:SetAttribute(\"type1\", \"item\")\n    btn:SetAttribute(\"item1\", \"item:\" .. aura_env.itemid)\n    \n    -- 右键：施放法术 \"制造魔法红宝石\"\n    btn:SetAttribute(\"type2\", \"spell\")\n    btn:SetAttribute(\"spell2\", \"制造魔法红宝石\")\nend\n\nbtn:Hide()\naura_env.button = btn\n\n",
["do_custom"] = true,
},
},
["triggers"] = {
{
["trigger"] = {
["use_exact_itemName"] = true,
["use_count"] = true,
["duration"] = "1",
