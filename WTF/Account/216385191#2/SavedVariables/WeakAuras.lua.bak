["德鲁伊：野性印记、野性赐福"] = {
["text2Point"] = "CENTER",
["iconSource"] = -1,
["text1FontSize"] = 12,
["authorOptions"] = {
},
["adjustedMax"] = "",
["yOffset"] = 0,
["anchorPoint"] = "CENTER",
["url"] = "https://space.bilibili.com/455259",
["actions"] = {
["start"] = {
