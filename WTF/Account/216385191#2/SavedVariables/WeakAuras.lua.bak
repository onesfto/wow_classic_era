["regionType"] = "icon",
["customText"] = "function()\n    if WeakAuras.IsOptionsOpen() then\n        return \"|cffffffff技能名|r\"\n    end\n    \n    local spellName = aura_env.state.spellName \n    or aura_env.state.name\n    \n    if not spellName and aura_env.state.spellId then\n        spellName = C_Spell.GetSpellName(aura_env.state.spellId)\n    end\n    \n    if not spellName then\n        return nil\n    end\n    \n    local nameInBrackets = spellName:match(\"%((.+)%)\")\n    if nameInBrackets then\n        spellName = nameInBrackets\n    end\n    \n    local shortNames = {\n        [\"节能施法\"] = \"节能\",\n    }\n    \n    if #spellName >= 3 then\n        return shortNames[spellName] or spellName\n    else\n        return spellName\n    end\nend",
