["alpha"] = 0.7,
["x"] = 5,
["y"] = 5,
["colorType"] = "straightColor",
["preset"] = "grow",
["scaleFunc"] = "function(progress, startX, startY, scaleX, scaleY)\n    return startX + (progress * (scaleX - startX)), startY + (progress * (scaleY - startY))\nend\n",
