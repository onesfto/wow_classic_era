["event"] = "Health",
["dynamicDuration"] = false,
["names"] = {
},
["spellIds"] = {
},
["custom"] = "function(allstate,event,_, encounterName, _, groupSize, success)\n    --Author：猫屋敷雪风，for 露露緹婭@Bilibili，转载请保留出处，请勿二次上传WAGO\n    --如果不是encounter end触发的事件，无视掉\n    if event ~= \"ENCOUNTER_END\" then\n        return false\n    end\n    \n    --如果是五人本，无视掉\n    if groupSize ==5 then\n        return false\n    end\n    \n    --debug用\n    --print(\"遭遇战结束\") --记得删除print\n    --print(\"副本人数=\"..groupSize)\n    \n    if success==1 then\n        --print(\"战斗胜利\")\n        PlaySoundFile(\"Interface\\\\AddOns\\\\Rurutia\\\\【露露】笨笨辛苦啦.ogg\", \"Master\")\n    end\n    \n    return false\nend",
["custom_type"] = "stateupdate",
["check"] = "event",
["events"] = "ENCOUNTER_END",
["subeventPrefix"] = "SPELL",
["custom_hide"] = "timed",
},
["untrigger"] = {
